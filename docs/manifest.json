{
  "name": "Cookio",
  "short_name": "cookio",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#5987B8",
  "icons": [
    { "type": "image/png", "src": "/android-launchericon-512-512.png", "sizes": "512x512" },
    { "type": "image/png", "src": "/android-launchericon-192-192.png", "sizes": "192x192" }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "files": [
        {
          "name": "image",
          "accept": ["image/png", "image/jpeg", "image/webp", "image/gif"]
        }
      ]
    }
  }
}
